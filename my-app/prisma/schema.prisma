generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// --- ENUMS (ПЕРЕЧИСЛЕНИЯ) ---
// ==========================================

enum Role {
  USER
  PRODUCER
  ADMIN
}

enum SoundPackCategory {
  DRUMKITS
  LOOPS
  PRESETS
}

enum NotificationType {
  LIKE
  INQUIRY_RECEIVED // Новый лид/запрос для продюсера
  INQUIRY_UPDATED // Изменение статуса запроса для покупателя
  FOLLOW
  PLAYLIST
  SYSTEM
}

// Статусы обработки запроса на покупку внутри нашей CRM-системы
enum InquiryStatus {
  PENDING // Запрос отправлен артистом, ожидает ответа продюсера
  CONTACTED // Продюсер нажал кнопку и связался с покупателем напрямую
  COMPLETED // Сделка успешно закрыта, деньги переведены на карту продюсера
  DECLINED // Продюсер отклонил запрос (например, бит уже продан эксклюзивно)
  ARCHIVED // Архивный или неактуальный запрос
}


// Состояния PRO-подписки создателя на нашу платформу
enum SubscriptionStatus {
  INACTIVE // Подписка не оформлялась или полностью истекла
  ACTIVE // Подписка оплачена и активна
  PAST_DUE // Ошибка автопродления (карта пуста), ожидает повторного списания
  CANCELED // Отменена пользователем, но действует до конца оплаченного периода
}

enum OrderStatus {
  PENDING_PAYMENT // Ожидает оплаты (создан запрос)
  PAYMENT_SUBMITTED // Покупатель прикрепил чек, ждет подтверждения от продавца
  PAID // Продавец подтвердил, файлы доступны для скачивания
  COMPLETED // Покупатель подтвердил получение файлов, сделка закрыта
  DISPUTE // Открыт спор, на рассмотрении модератора
  CANCELLED // Отменен
}

// ==========================================
// --- CORE MODELS (ОСНОВНЫЕ МОДЕЛИ) ---
// ==========================================

model User {
  id          String  @id @default(uuid())
  email       String  @unique
  username    String  @unique
  password    String? // Хэш пароля (nullable на случай будущего добавления OAuth/Google)
  displayName String?
  role        Role    @default(USER)

  // Визуальное оформление и позиционирование
  avatar        String?
  biography     String?
  location      String?
  verified      Boolean @default(false) // Системная "галочка" верификации
  isTopProducer Boolean @default(false) // Вывод автора на главную страницу в топ

  // Прямые каналы связи для совершения сделок напрямую вне платформы
  telegram  String?
  instagram String?
  vkontakte String?
  website   String?
  paymentDetails String?

  // Счетчики популярности
  followersCount Int @default(0)
  totalPlays     Int @default(0)

  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ----------------------------------------------------
  // ПОДПИСКА НА ПЛАТФОРМУ (SaaS логика ограничений)
  // ----------------------------------------------------
  subscriptionId        String?
  subscription          SubscriptionPlan?  @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  subscriptionStatus    SubscriptionStatus @default(INACTIVE)
  subscriptionExpiresAt DateTime? // Точная дата и время, когда нужно отключить PRO-функции
  paymentCustomerId     String? // Уникальный ID покупателя в платежной системе (для рекуррентных платежей)
  paymentSubscriptionId String? // ID подписки на стороне эквайринга (для отмены/продления по Webhook)

  // Реляционные связи контента
  tracks           Track[]
  soundPacks       SoundPack[]
  likes            Like[]
  notifications    Notification[]
  licenseTemplates LicenseTemplate[]
  playlists        Playlist[]
  cartItems CartItem[]

  // Связи с запросами на покупку (как покупатель и как продавец)
  sentInquiries     Inquiry[] @relation("BuyerInquiries")
  receivedInquiries Inquiry[] @relation("ProducerInquiries")

  //Фоловеры
  following Follow[] @relation("Following")
  followers Follow[] @relation("Followers")

  //Ордеры
  ordersAsBuyer  Order[]       @relation("BuyerOrders")
  ordersAsSeller Order[]       @relation("SellerOrders")
  messages       ChatMessage[]
  disputes       Dispute[]
}

model Order {
  id           String      @id @default(uuid())
  buyerId      String
  sellerId     String
  status       OrderStatus @default(PENDING_PAYMENT)
  paymentProof String? // Ссылка на скриншот чека об оплате
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  buyer  User @relation("BuyerOrders", fields: [buyerId], references: [id])
  seller User @relation("SellerOrders", fields: [sellerId], references: [id])

  items    OrderItem[]
  messages ChatMessage[]
  disputes Dispute[]

  @@index([buyerId])
  @@index([sellerId])
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  trackId   String
  licenseId String

  user      User     @relation(fields: [userId], references: [id])
  track     Track    @relation(fields: [trackId], references: [id])
  license   License  @relation(fields: [licenseId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, trackId]) // Чтобы один трек не добавить дважды
}

model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  trackId   String
  licenseId String // Какая лицензия была выбрана

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  track   Track   @relation(fields: [trackId], references: [id])
  license License @relation(fields: [licenseId], references: [id])
}

model ChatMessage {
  id        String   @id @default(uuid())
  orderId   String
  senderId  String
  text      String
  isSystem  Boolean  @default(false) // Для сообщений типа "Покупатель отметил заказ как оплаченный"
  createdAt DateTime @default(now())

  order  Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sender User  @relation(fields: [senderId], references: [id])
}

model Dispute {
  id         String    @id @default(uuid())
  orderId    String
  raisedById String // Кто открыл спор (обычно покупатель)
  reason     String // Описание проблемы
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  order    Order @relation(fields: [orderId], references: [id])
  raisedBy User  @relation(fields: [raisedById], references: [id])
}

model Follow {
  id          String @id @default(uuid())
  followerId  String
  followingId String

  follower  User @relation("Following", fields: [followerId], references: [id])
  following User @relation("Followers", fields: [followingId], references: [id])

  createdAt DateTime @default(now())

  @@unique([followerId, followingId]) // Чтобы нельзя было подписаться дважды
  @@index([followerId])
  @@index([followingId])
}

model Track {
  id        String  @id @default(uuid())
  title     String
  bpm       Int
  musicKey  String
  image     String?
  audio     String
  duration  Int
  plays     Int     @default(0)
  downloads Int     @default(0)

  wavUrl             String?  // Ссылка на HQ WAV файл
  stemsUrl           String?  // Ссылка на архивы дорожек (Google Drive / Uploadthing)

  featured           Boolean @default(false)
  isSpotlight        Boolean @default(false)
  exclusiveAvailable Boolean @default(true)
  isActive           Boolean @default(true)

  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  producerId String
  producer   User   @relation(fields: [producerId], references: [id], onDelete: Cascade)

  genreId String
  genre   Genre  @relation(fields: [genreId], references: [id], onDelete: Restrict)

  // ДОБАВЛЕНО: Связь с настроениями (Многие-ко-многим для гибкости)
  moods Mood[] @relation("TrackMoods")

  playlists    Playlist[]    @relation("PlaylistTracks")
  licenses     License[]
  likes        Like[]
  inquiryItems InquiryItem[]
  orderItems   OrderItem[]
  cartItems CartItem[]
}

// ДОБАВЛЕНО: Новая модель для Настроений (Грустный, Агрессивный, Энергичный и т.д.)
model Mood {
  id        String   @id @default(uuid())
  name      String   @unique // "Агрессивный", "Грустный"
  slug      String   @unique // "dark", "sad", "energetic"
  createdAt DateTime @default(now())

  tracks    Track[]    @relation("TrackMoods")
  playlists Playlist[] @relation("PlaylistMoods")

  @@map("mood")
}

model Playlist {
  id          String   @id @default(uuid())
  title       String
  description String?
  image       String?
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tracks Track[] @relation("PlaylistTracks")

  // ДОБАВЛЕНО: Связь с настроениями для фильтрации "По настроению"
  moods Mood[] @relation("PlaylistMoods")

  // ДОБАВЛЕНО: Тип плейлиста для фильтра в сайдбаре ("featured", "albums", "moods")
  type       String  @default("moods")
  producerId String? // Добавь это
  producer   User?   @relation(fields: [producerId], references: [id]) // И это
  // Если нужно поле приватности:
  isPrivate  Boolean @default(false)

  @@map("playlist")
}

model SoundPack {
  id          String   @id @default(uuid())
  title       String
  price       Float
  image       String?
  soundsCount Int      @default(0)
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  // ДОБАВЛЕНО: Категория пака
  category SoundPackCategory @default(DRUMKITS)

  producerId String
  producer   User   @relation(fields: [producerId], references: [id], onDelete: Cascade)

  @@map("soundpack")
}

model Genre {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tracks Track[]

  @@map("genre")
}

// ==========================================
// --- LICENSES & CONTRACTS (КОНТРАКТЫ) ---
// ==========================================

model LicenseTemplate {
  id              String          @id @default(uuid())
  name            String // Название ("Standard WAV Lease", "Exclusive Contract")
  slug            String // Машиночитаемый тип ("mp3", "wav", "stems", "exclusive")
  defaultPrice    Float? // Теперь может быть null
  fileType          LicenseFileType @default(MP3)
  isDefaultActive Boolean         @default(true)
  isPriceNegotiable Boolean @default(false) // Если true, цена не отображается

  // Юридические параметры контракта, которые подставляются в бланк лида
  arbitrationCountry        String  @default("Russia")
  governingLawCountry       String  @default("Russia")
  termYears                 Int? // null = Безлимитный срок
  distributionCopies        Int? // Макс. тираж копий
  audioStreams              Int? // Макс. стримы (Spotify/Apple Music)
  freeDownloads             Int?
  musicVideosMonetized      Int?
  musicVideosNonMonetized   Int?
  videoStreamsMonetized     Int?
  videoStreamsNonMonetized  Int?
  radioBroadcastingRights   Boolean @default(false)
  radioStations             Int?
  livePerformancesForProfit Boolean @default(false)
  livePerformancesNonProfit Int?

  producerId    String
  producer      User      @relation(fields: [producerId], references: [id], onDelete: Cascade)
  trackLicenses License[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum LicenseFileType {
  MP3             // Только MP3
  MP3_WAV         // MP3 + HQ WAV
  MP3_WAV_STEMS   // MP3 + HQ WAV + Дорожки (Stems)
}

model License {
  id       String  @id @default(uuid())
  price    Float?  // Изменено: Кастомная цена или null (если договорная)
  isActive Boolean @default(true)

  trackId String
  track   Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)

  templateId String
  template   LicenseTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  inquiryItems InquiryItem[]
  orderItems   OrderItem[]
  cartItems CartItem[]

  @@unique([trackId, templateId])
}

model Like {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  trackId String
  track   Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
}

// ==========================================
// --- CRM INQUIRIES (СИСТЕМА ЗАПРОСОВ) ---
// ==========================================

model Inquiry {
  id           String        @id @default(uuid())
  status       InquiryStatus @default(PENDING)
  message      String? // Сопроводительное сообщение/пожелание от артиста
  buyerContact String // Контактные данные покупателя (Ник в Telegram, Ссылка на соцсеть)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Покупатель (Артист)
  buyerId String
  buyer   User   @relation("BuyerInquiries", fields: [buyerId], references: [id], onDelete: Cascade)

  // Продавец (Продюсер)
  producerId String
  producer   User   @relation("ProducerInquiries", fields: [producerId], references: [id], onDelete: Cascade)

  items InquiryItem[]
}

model InquiryItem {
  id             String @id @default(uuid())
  priceAtInquiry Float? // Изменено: Снапшот цены на момент запроса (может быть null)

  inquiryId String
  inquiry   Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  trackId String
  track   Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)

  licenseId String?
  license   License? @relation(fields: [licenseId], references: [id], onDelete: SetNull)
}

// ==========================================
// --- SAAS SUBSCRIPTION PLANS (ТАРИФЫ) ---
// ==========================================

model SubscriptionPlan {
  id           String  @id @default(uuid())
  title        String // "FREE", "PRO_CREATOR", "ELITE_STUDIO"
  description  String
  monthlyPrice Float
  yearlyPrice  Float
  popular      Boolean @default(false)

  // Конфигурационный JSON лимитов (Пример: { "maxTracks": 5, "allowSpotlight": false, "keepExclusives": true })
  features Json

  users User[]
}

// ==========================================
// --- SYSTEM UTILS (УВЕДОМЛЕНИЯ) ---
// ==========================================

model Notification {
  id          String           @id @default(uuid())
  type        NotificationType
  title       String
  description String
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}


// Таблица-очередь для отслеживания загруженных, но не привязанных к трекам файлов (защита от сирот)
model UploadQueue {
  id        String   @id @default(cuid())
  fileKey   String   @unique
  createdAt DateTime @default(now())

  @@index([createdAt]) // Индекс для быстрого поиска старых файлов
}